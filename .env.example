# Copy to .env and adjust. Read by docker-compose and by the backend directly.

# ---- Ports -------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000
# Next.js server-side rewrite target (inside docker compose: http://backend:8000)
BACKEND_URL=http://localhost:8000

# ---- Paths (relative paths resolve against backend/) ---------------------------
MODELS_DIR=models
OUTPUTS_DIR=outputs
ASSETS_DIR=assets

# ---- Input limits ----------------------------------------------------------------
MAX_UPLOAD_MB=20
# ~20 minutes of spoken English at a natural pace (~900 chars/minute)
MAX_SCRIPT_CHARS=20000
MAX_PROMPT_CHARS=1000

# ---- Jobs -----------------------------------------------------------------------
# Hard per-job time limit; a hung job is failed after this many seconds.
# Talking head processes at ~1-3 min per minute of script, so long scripts need room.
JOB_TIMEOUT_S=7200
RECENT_JOBS_LIMIT=20

# ---- GPU / model manager -----------------------------------------------------------
WAN_VARIANT=ti2v-5b
# Free VRAM headroom the model manager keeps before admitting a pipeline (GB).
VRAM_RESERVE_GB=2
# Offload policy per pipeline: cpu = move idle weights to system RAM (fast to
# restore), unload = free them entirely (slow restore, zero RAM cost).
S2_OFFLOAD=cpu
MUSETALK_OFFLOAD=cpu
WAN_OFFLOAD=cpu

# ---- Logging -------------------------------------------------------------------------
# pretty | json
LOG_FORMAT=pretty
