# Copy to .env and adjust. Read by docker-compose and by the backend directly.

# ---- Ports -------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000
# Next.js server-side rewrite target (inside docker compose: http://backend:8000)
BACKEND_URL=http://localhost:8000

# ---- Paths (relative paths resolve against backend/) ---------------------------
MODELS_DIR=models
OUTPUTS_DIR=outputs
ASSETS_DIR=assets

# ---- Input limits ----------------------------------------------------------------
MAX_UPLOAD_MB=20
# ~20 minutes of spoken English at a natural pace (~900 chars/minute)
MAX_SCRIPT_CHARS=20000
MAX_PROMPT_CHARS=1000

# ---- Jobs -----------------------------------------------------------------------
# Hard per-job time limit; a hung job is failed after this many seconds.
# Talking head processes at ~1-3 min per minute of script, so long scripts need room.
JOB_TIMEOUT_S=7200
RECENT_JOBS_LIMIT=20

# ---- Style LoRA training (ostris/ai-toolkit, Wan2.2 5B base) -------------------------
# Dataset size bounds for a training job; 20-50 varied images is the sweet spot.
LORA_MIN_IMAGES=5
LORA_MAX_IMAGES=60
LORA_DEFAULT_STEPS=2000
LORA_MAX_STEPS=4000
# Training gets its own timeout: ~1.5-3 s/step on the L40S ≈ 1-2 h for 2000 steps.
LORA_TIMEOUT_S=21600
# The trainer's venv and entry script inside the backend container (Dockerfile).
TRAINER_PYTHON=/opt/trainer-venv/bin/python
TRAINER_SCRIPT=/opt/ai-toolkit/run.py

# ---- GPU / model manager -----------------------------------------------------------
WAN_VARIANT=ti2v-5b
# Free VRAM headroom the model manager keeps before admitting a pipeline (GB).
VRAM_RESERVE_GB=2
# Offload policy per pipeline: cpu = move idle weights to system RAM (fast to
# restore), unload = free them entirely (slow restore, zero RAM cost).
# S2 must stay "unload": parking it in RAM next to Wan swap-freezes a 64 GB host.
S2_OFFLOAD=unload
MUSETALK_OFFLOAD=cpu
WAN_OFFLOAD=cpu
# FLUX (~34 GB bf16) would blow the 64 GB host RAM if parked there next to Wan.
FLUX_OFFLOAD=unload

# ---- Model tiers ---------------------------------------------------------------------
# true registers the premium (H100-class) engines: Wan2.2 A14B etc. Leave false
# on the L40S — those models don't fit its 44 GB. See SERVICE_ARCHITECTURE.md.
PREMIUM_ENABLED=false

# ---- Logging -------------------------------------------------------------------------
# pretty | json
LOG_FORMAT=pretty
