# Nginx reverse proxy for AI Video Studio.
#
# Install:  sudo cp deploy/nginx.conf.example /etc/nginx/sites-available/ai-video-studio
#           sudo ln -s /etc/nginx/sites-available/ai-video-studio /etc/nginx/sites-enabled/
#           sudo rm -f /etc/nginx/sites-enabled/default
#
# Replace studio.example.com with your subdomain everywhere, then:
#   HTTPS:       sudo apt install certbot python3-certbot-nginx
#                sudo certbot --nginx -d studio.example.com
#   (certbot rewrites this file with the ssl_certificate lines and the :80
#    redirect automatically, and installs auto-renewal.)

server {
    listen 80;
    server_name studio.example.com;

    # No basic auth: the app has real accounts (NextAuth) and the backend
    # requires a Bearer JWT on /api — but only when AUTH_ENABLED=true in .env.
    # Never remove basic auth while that flag is off.

    # Avatar/reference uploads (backend enforces its own limit too).
    client_max_body_size 100m;

    # Generation status polling is snappy, but big video downloads are not.
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;

    # NextAuth lives under /api/auth/ on the Next server, not the backend.
    # Longest-prefix match wins, so this carves it out of the /api/ block below.
    location /api/auth/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # API + generated files go straight to the backend, skipping the Next hop.
    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /outputs/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_buffering off;
    }

    # Everything else is the Next.js UI.
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
